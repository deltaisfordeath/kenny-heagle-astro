---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';

type Post = CollectionEntry<'posts'>;

export async function getStaticPaths() {
  const posts: Post[] = await getCollection('posts', ({ data }: Post) => !data.draft);
  const tags = [...new Set(posts.flatMap(p => p.data.tags))];
  return tags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  tag: string;
  posts: Post[];
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag} — Kenny Heagle`} description={`Posts tagged "${tag}"`}>
  <div class="container">
    <header class="page-header">
      <p class="page-header__back"><a href="/blog">&larr; All posts</a></p>
      <h1 class="page-header__title">#{tag}</h1>
      <p class="page-header__desc">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
    </header>

    <section class="post-list">
      {posts.map((post: Post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }

  .page-header__back {
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
  }

  .page-header__title {
    font-size: 2rem;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .page-header__desc {
    color: var(--color-text-muted);
    margin: 0;
  }

  .post-list {
    padding-bottom: 3rem;
  }
</style>
