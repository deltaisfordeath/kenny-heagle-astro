---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { Image } from "astro:assets";
import { getPublishedPosts } from "../util/posts";
import { PATH_TO_BLOG, PATH_TO_PROJECTS } from "../util/constants";
import triathlonPhoto from "../assets/images/kenny-triathlon.jpeg";

const recentPosts = (await getPublishedPosts()).slice(0, 5);
---

<BaseLayout description="Writing on tech, business, finance, and fitness.">
  <div class="container">
    <section class="hero">
      <div class="hero__text">
        <h1 class="hero__name">Kenny Heagle</h1>
        <p class="hero__tagline">CPA • Developer • Triathlete</p>
        <p class="hero__bio">
          Hi, I&apos;m Kenny. I teach computers to do useful things. My
          background is an unusual blend of finance and tech: a bachelor&apos;s
          in Accounting and years in real estate, risk analysis, and
          underwriting, then a pivot into software — a Master&apos;s in
          Computer Science, a CPA license, and data engineering work at an
          accounting firm.
        </p>
        <p class="hero__bio">
          To balance the desk hours I spend as much time as I can outdoors,
          competing in distance running and triathlons. On the
          <a href={PATH_TO_BLOG}>blog</a> I write about technology, business,
          and fitness.
        </p>
        <div class="hero__links">
          <a href={PATH_TO_BLOG} class="btn">Read the blog</a>
          <a href={PATH_TO_PROJECTS} class="btn btn--ghost">Projects</a>
        </div>
      </div>
      <div class="hero__photo">
        <Image
          src={triathlonPhoto}
          alt="Kenny giving a thumbs up mid-race at a triathlon"
          width={340}
          quality={85}
        />
      </div>
    </section>

    <section class="recent-posts">
      <div class="section-header">
        <h2 class="section-header__title">Recent Posts</h2>
        <a href={PATH_TO_BLOG} class="section-header__link">All posts &rarr;</a>
      </div>
      {
        recentPosts.length === 0 ? (
          <p class="empty-state">No posts yet — check back soon.</p>
        ) : (
          recentPosts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              tags={post.data.tags}
            />
          ))
        )
      }
    </section>
  </div>
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .hero__text {
    flex: 1;
  }

  .hero__photo {
    flex-shrink: 0;
  }

  .hero__photo img {
    border-radius: 16px;
    border: 1px solid var(--color-border);
    width: 300px;
    height: auto;
  }

  .hero__name {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .hero__tagline {
    font-size: 1.1rem;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero__bio {
    color: var(--color-text-muted);
    max-width: 620px;
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .hero__links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  @media (max-width: 720px) {
    .hero {
      flex-direction: column-reverse;
      gap: 2rem;
      padding-top: 2.5rem;
    }

    .hero__photo img {
      width: 220px;
    }
  }

  .btn {
    display: inline-block;
    padding: 0.55rem 1.25rem;
    background: var(--color-accent);
    color: #0d1117;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .btn:hover {
    background: var(--color-accent-hover);
    text-decoration: none;
    color: #0d1117;
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn--ghost:hover {
    background: var(--color-surface);
    color: var(--color-text);
    border-color: var(--color-accent);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .section-header__title {
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .section-header__link {
    font-size: 0.85rem;
  }

  .recent-posts {
    padding-bottom: 3rem;
  }

  .empty-state {
    color: var(--color-text-muted);
    padding: 2rem 0;
  }
</style>
