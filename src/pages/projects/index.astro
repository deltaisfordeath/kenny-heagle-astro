---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

// Add projects here. Import images from src/assets/images/ for optimization.
// Example: import myProjectImage from '../../assets/images/my-project.png';
const projects = [
  {
    name: 'Hardcore Accountability',
    description:
      'A personal productivity tracker that keeps score across the whole picture: fitness and nutrition, productive vs. unproductive time, tasks and to-dos, and mood and mental health.',
    url: 'https://hardcoreaccountability.com',
    tags: ['Web App', 'Productivity', 'Fitness'],
  },
  {
    name: 'Kardio Karaoke',
    description:
      'A YouTube channel where participants run on treadmills and try to sing karaoke despite running out of breath. Exactly as hard as it sounds.',
    url: 'https://www.kardiokaraoke.com',
    tags: ['YouTube', 'Fitness', 'Comedy'],
    socialLinks: [
      { platform: 'youtube', href: 'https://youtube.com/@kardiokaraoke' },
    ],
  },
];
---

<BaseLayout title="Projects" description="Projects I've built or collaborate on.">
  <div class="container">
    <header class="page-header">
      <h1 class="page-header__title">Projects</h1>
      <p class="page-header__desc">Things I've built, contributed to, or partner on — mine and those of friends.</p>
    </header>

    {projects.length === 0 ? (
      <p class="empty-state">Projects coming soon.</p>
    ) : (
      <div class="project-grid">
        {projects.map(project => (
          <ProjectCard {...project} />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .page-header__title {
    font-size: 2rem;
    margin-bottom: 0.4rem;
  }

  .page-header__desc {
    color: var(--color-text-muted);
    margin: 0;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    padding-bottom: 3rem;
  }

  .empty-state {
    color: var(--color-text-muted);
    padding: 3rem 0;
  }
</style>
