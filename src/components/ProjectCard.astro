---
import { Image } from 'astro:assets';

interface SocialLink {
  platform: 'github' | 'youtube' | 'instagram' | 'linkedin' | 'twitter' | 'website';
  href: string;
}

interface Props {
  name: string;
  description: string;
  url: string;
  image?: ImageMetadata;
  imageAlt?: string;
  socialLinks?: SocialLink[];
  tags?: string[];
}

const { name, description, url, image, imageAlt, socialLinks = [], tags = [] } = Astro.props;

