---
import TagList from "./TagList.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
}

const { title, description, pubDate, slug, tags } = Astro.props;

const formatted = new Date(pubDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="post-card__link">
    <h2 class="post-card__title">{title}</h2>
  </a>
  <time class="post-card__date" datetime={new Date(pubDate).toISOString()}
    >{formatted} {pubDate.toISOString()}</time
  >
  <p class="post-card__desc">{description}</p>
  {tags.length > 0 && <TagList tags={tags} />}
</article>

<style>
  .post-card {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-card__link {
    text-decoration: none;
  }

  .post-card__link:hover .post-card__title {
    color: var(--color-accent);
  }

  .post-card__title {
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
    transition: color 0.15s;
  }

  .post-card__date {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 0.5rem;
  }

  .post-card__desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }
</style>
