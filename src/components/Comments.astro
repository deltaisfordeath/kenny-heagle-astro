---
// Remark42 comments — self-hosted on the Mac mini, exposed via cloudflared.
// Server setup: see deploy/remark42/README.md
const REMARK_HOST = "https://comments.kennyheagle.com";
const SITE_ID = "kennyheagle";
---

<section class="comments">
  <h2 class="comments__heading">Comments</h2>
  <div id="remark42"></div>
</section>

<script is:inline define:vars={{ REMARK_HOST, SITE_ID }}>
  window.remark_config = {
    host: REMARK_HOST,
    site_id: SITE_ID,
    components: ["embed"],
    theme: "dark",
    show_email_subscription: false,
  };

  (function (components, d) {
    for (var i = 0; i < components.length; i++) {
      var s = d.createElement("script");
      s.type = "module";
      s.src = window.remark_config.host + "/web/" + components[i] + ".mjs";
      s.defer = true;
      (d.head || d.body).appendChild(s);
    }
  })(window.remark_config.components || ["embed"], document);
</script>

<style>
  .comments {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .comments__heading {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
  }
</style>
